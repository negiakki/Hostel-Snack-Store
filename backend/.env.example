NODE_ENV=development
PORT=3001
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/hostel_snack_store?schema=public"

# Comma-separated origins are supported for preview deployments.
FRONTEND_URL=http://localhost:3000

# Generate with a cryptographically secure generator, for example:
# node -e "console.log(require('crypto').randomBytes(48).toString('base64url'))"
JWT_SECRET=replace-with-a-cryptographically-secure-random-string-at-least-32-characters
ADMIN_NAME=Store Admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=replace-with-a-long-unique-admin-password
STORAGE_BUCKET=hostel-snack-store
STORAGE_ENDPOINT=https://your-project.supabase.co/storage/v1
STORAGE_ACCESS_KEY=replace-before-storage-implementation
STORAGE_SECRET_KEY=replace-before-storage-implementation
